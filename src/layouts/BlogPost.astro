---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BackToTop from '../components/BackToTop.astro';
import BaseHead from '../components/BaseHead.astro';
import CopyCode from '../components/CopyCode.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Giscus from '../components/Giscus.astro';
import Header from '../components/Header.astro';
import ReadingTime from '../components/ReadingTime.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { body?: string };

const { title, description, pubDate, updatedDate, heroImage, tags, body = '' } = Astro.props;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	"headline": title,
	"description": description,
	"datePublished": pubDate.toISOString(),
	...(updatedDate && { "dateModified": updatedDate.toISOString() }),
	"author": {
		"@type": "Person",
		"name": "SSHeRun",
		"url": "https://ssherun.github.io"
	},
	"publisher": {
		"@type": "Person",
		"name": "SSHeRun"
	},
	"url": new URL(Astro.url.pathname, Astro.site).toString(),
	"inLanguage": "zh-CN",
	...(tags && tags.length > 0 && { "keywords": tags.join(", ") }),
};
---

<html lang="zh-CN">
	<head>
		<BaseHead title={`${title} - ${SITE_TITLE}`} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<div class="article-header">
					<div class="meta">
						<FormattedDate date={pubDate} />
						{updatedDate && (
							<span class="updated">
								(更新于 <FormattedDate date={updatedDate} />)
							</span>
						)}
						<span class="dot">·</span>
						<ReadingTime content={body} />
					</div>
					<h1>{title}</h1>
					{tags && tags.length > 0 && (
						<div class="tags">
							{tags.map((tag: string) => (
								<span class="tag">{tag}</span>
							))}
						</div>
					)}
				</div>
				<div class="prose">
					<slot />
				</div>
				<Giscus />
			</article>
		</main>
		<Footer />
		<BackToTop />
		<CopyCode />
	</body>
</html>

<style>
	main {
		max-width: 760px;
	}
	article {
		padding: 2rem 0;
	}
	.hero-image {
		margin-bottom: 2rem;
	}
	.hero-image img {
		width: 100%;
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-lg);
	}
	.article-header {
		margin-bottom: 2.5rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--border-color);
	}
	.article-header h1 {
		font-size: 2rem;
		margin: 0.5rem 0 0.75rem;
		letter-spacing: -0.03em;
		line-height: 1.3;
	}
	.meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.9rem;
		color: var(--text-tertiary);
	}
	.dot {
		color: var(--text-tertiary);
		opacity: 0.5;
	}
	.updated {
		color: var(--text-tertiary);
		font-size: 0.85rem;
	}
	.tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}
	.tag {
		padding: 0.2rem 0.65rem;
		background: color-mix(in srgb, var(--accent) 10%, transparent);
		color: var(--accent);
		border-radius: 999px;
		font-size: 0.8rem;
		font-weight: 500;
	}
	.prose {
		font-size: 1.05rem;
		line-height: 1.8;
	}
	.prose :global(h2) {
		margin-top: 2.5rem;
	}
	.prose :global(h3) {
		margin-top: 2rem;
	}
	.prose :global(p) {
		margin-bottom: 1.5em;
	}
	.prose :global(pre) {
		margin: 1.5em 0;
	}
	.prose :global(img) {
		border-radius: var(--radius-md);
		margin: 1.5em 0;
	}
	@media (max-width: 720px) {
		.article-header h1 {
			font-size: 1.6rem;
		}
	}
</style>
