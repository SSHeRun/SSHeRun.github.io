---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1 class="page-title">全部文章</h1>
				<span class="post-count">共 {posts.length} 篇</span>
			</div>

			<div class="post-grid">
				{posts.map((post) => (
					<a href={`/blog/${post.id}/`} class="post-card">
						{post.data.heroImage && (
							<div class="card-image">
								<Image
									src={post.data.heroImage}
									alt={post.data.title}
									width={640}
									height={320}
									loading="lazy"
									transition:name={`post-img-${post.id}`}
								/>
							</div>
						)}
						<div class="card-body">
							<div class="post-meta">
								<span class="date"><FormattedDate date={post.data.pubDate} /></span>
								{post.data.tags && (
									<div class="tags">
										{post.data.tags.map((tag: string) => (
											<span class="tag">{tag}</span>
										))}
									</div>
								)}
							</div>
							<h2>{post.data.title}</h2>
							{post.data.description && (
								<p class="description">{post.data.description}</p>
							)}
						</div>
					</a>
				))}
			</div>
		</main>
		<Footer />

		<style>
			main {
				max-width: var(--max-width-wide);
			}
			.page-header {
				display: flex;
				align-items: baseline;
				gap: 1rem;
				margin: 2rem 0 2.5rem;
			}
			.page-title {
				font-size: 2rem;
				margin: 0;
				letter-spacing: -0.03em;
			}
			.post-count {
				color: var(--text-muted);
				font-size: 0.9rem;
			}

			/* ── Grid ── */
			.post-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
				gap: 1.5rem;
			}

			/* ── Card ── */
			.post-card {
				display: flex;
				flex-direction: column;
				border-radius: var(--radius-lg);
				text-decoration: none;
				border: 1px solid var(--glass-border);
				overflow: hidden;
				background: var(--glass-bg);
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
				transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
			}
			.post-card:hover {
				border-color: var(--border-glow);
				transform: translateY(-3px);
				box-shadow: var(--shadow-glow), var(--shadow-lg);
			}

			/* ── Card Image ── */
			.card-image {
				width: 100%;
				aspect-ratio: 2 / 1;
				overflow: hidden;
			}
			.card-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.45s ease;
			}
			.post-card:hover .card-image img {
				transform: scale(1.06);
			}

			/* ── Card Body ── */
			.card-body {
				padding: 1.25rem;
				flex: 1;
				display: flex;
				flex-direction: column;
			}
			.card-body h2 {
				font-size: 1.1rem;
				margin: 0.5rem 0;
				color: var(--text-primary);
				line-height: 1.4;
				letter-spacing: -0.01em;
			}
			.description {
				font-size: 0.875rem;
				color: var(--text-secondary);
				margin: 0;
				line-height: 1.6;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
				flex: 1;
			}

			/* ── Meta ── */
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				font-size: 0.8rem;
			}
			.date {
				color: var(--text-muted);
			}
			.tags {
				display: flex;
				gap: 0.375rem;
				flex-wrap: wrap;
			}
			.tag {
				padding: 0.1rem 0.5rem;
				background: color-mix(in srgb, var(--accent) 12%, transparent);
				color: var(--accent);
				border-radius: 999px;
				font-size: 0.72rem;
				font-weight: 500;
				letter-spacing: 0.02em;
			}

			@media (max-width: 720px) {
				.post-grid {
					grid-template-columns: 1fr;
				}
				.page-header {
					flex-direction: column;
					gap: 0.25rem;
				}
			}
		</style>
	</body>
</html>
