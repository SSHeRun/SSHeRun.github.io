---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-mesh"></div>
				<div class="hero-content">
					<span class="hero-pill glass">Agent-Friendly Blog</span>
					<h1>一个对 <span class="accent">Agent</span> 友好的博客</h1>
					<p class="subtitle">不只是给人看的网站，也是给 AI 读的接口。探索 Agent 时代个人网站的新形态。</p>
				</div>
			</section>

			<section class="recent-posts">
				<div class="section-header">
					<h2>最新文章</h2>
					<a href="/blog" class="view-all">查看全部 &rarr;</a>
				</div>
				<div class="post-list">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="post-card">
							{post.data.heroImage && (
								<div class="post-image">
									<Image
										src={post.data.heroImage}
										alt={post.data.title}
										width={320}
										height={180}
										loading="lazy"
										transition:name={`post-img-${post.id}`}
									/>
								</div>
							)}
							<div class="post-body">
								<div class="post-meta">
									<FormattedDate date={post.data.pubDate} />
									{post.data.tags && (
										<div class="tags">
											{post.data.tags.map((tag: string) => (
												<span class="tag">{tag}</span>
											))}
										</div>
									)}
								</div>
								<h3>{post.data.title}</h3>
								{post.data.description && <p>{post.data.description}</p>}
							</div>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />

		<style>
			main {
				max-width: var(--max-width-wide);
			}

			/* ── Hero ── */
			.hero {
				position: relative;
				padding: 5rem 0 3.5rem;
				overflow: hidden;
			}
			.hero-mesh {
				position: absolute;
				inset: -60px;
				background:
					radial-gradient(ellipse 600px 350px at 70% 20%, color-mix(in srgb, var(--accent) 15%, transparent), transparent),
					radial-gradient(ellipse 500px 300px at 20% 70%, color-mix(in srgb, var(--accent-secondary) 12%, transparent), transparent),
					radial-gradient(ellipse 300px 200px at 50% 50%, color-mix(in srgb, var(--accent) 6%, transparent), transparent);
				filter: blur(50px);
				pointer-events: none;
				z-index: -1;
				animation: mesh-float 12s ease-in-out infinite alternate;
			}
			@keyframes mesh-float {
				0% {
					transform: translate(0, 0) scale(1);
				}
				33% {
					transform: translate(15px, -10px) scale(1.02);
				}
				66% {
					transform: translate(-10px, 8px) scale(0.98);
				}
				100% {
					transform: translate(5px, -5px) scale(1.01);
				}
			}
			.hero-content {
				position: relative;
			}
			.hero-pill {
				display: inline-block;
				font-size: 0.8rem;
				font-weight: 600;
				color: var(--accent);
				letter-spacing: 0.06em;
				text-transform: uppercase;
				padding: 0.3rem 0.9rem;
				border-radius: 999px;
				margin-bottom: 1.25rem;
				box-shadow: inset 0 0 0 1px var(--border-glow);
			}
			.hero h1 {
				font-size: 2.75rem;
				margin: 0 0 0.85rem;
				letter-spacing: -0.03em;
				line-height: 1.15;
			}
			.accent {
				background: var(--accent-gradient);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}
			.subtitle {
				font-size: 1.2rem;
				color: var(--text-muted);
				margin: 0;
				max-width: 560px;
				line-height: 1.7;
			}

			/* ── Section ── */
			.recent-posts {
				padding: 1.5rem 0 1rem;
			}
			.section-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 1.5rem;
			}
			.section-header h2 {
				font-size: 1.3rem;
				margin: 0;
				color: var(--text-primary);
				letter-spacing: -0.02em;
			}
			.view-all {
				font-size: 0.88rem;
				color: var(--text-muted);
				text-decoration: none;
				transition: color 0.2s ease;
			}
			.view-all:hover {
				color: var(--accent);
			}

			/* ── Post Cards ── */
			.post-list {
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}
			.post-card {
				display: flex;
				gap: 1.25rem;
				padding: 1rem;
				border-radius: var(--radius-lg);
				text-decoration: none;
				border: 1px solid transparent;
				transition: all 0.25s ease;
			}
			.post-card:hover {
				background: var(--glass-bg);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				border-color: var(--glass-border);
				transform: translateY(-2px);
				box-shadow: var(--shadow-md);
			}
			.post-image {
				flex-shrink: 0;
				width: 200px;
				height: 112px;
				border-radius: var(--radius-md);
				overflow: hidden;
			}
			.post-image img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.4s ease;
			}
			.post-card:hover .post-image img {
				transform: scale(1.06);
			}
			.post-body {
				flex: 1;
				min-width: 0;
				display: flex;
				flex-direction: column;
				justify-content: center;
			}
			.post-card h3 {
				font-size: 1.1rem;
				margin: 0.35rem 0 0.3rem;
				color: var(--text-primary);
				line-height: 1.4;
				letter-spacing: -0.01em;
			}
			.post-card p {
				font-size: 0.88rem;
				color: var(--text-secondary);
				margin: 0;
				line-height: 1.55;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.post-meta {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				font-size: 0.82rem;
				color: var(--text-muted);
			}
			.tags {
				display: flex;
				gap: 0.375rem;
			}
			.tag {
				padding: 0.1rem 0.5rem;
				background: color-mix(in srgb, var(--accent) 12%, transparent);
				color: var(--accent);
				border-radius: 999px;
				font-size: 0.72rem;
				font-weight: 500;
				letter-spacing: 0.02em;
			}

			@media (max-width: 720px) {
				.hero {
					padding: 3rem 0 2rem;
				}
				.hero h1 {
					font-size: 2rem;
				}
				.subtitle {
					font-size: 1.05rem;
				}
				.post-card {
					flex-direction: column;
					gap: 0.75rem;
				}
				.post-image {
					width: 100%;
					height: 160px;
				}
			}
		</style>
	</body>
</html>
